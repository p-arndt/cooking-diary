		"@types/d3-scale": "^4.0.9",
		"@types/node": "^25",
		"@types/nodemailer": "^7.0.9",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@vitejs/plugin-basic-ssl": "^2.1.4",
		"@vitest/browser": "^4.0.18",
		"bits-ui": "^2.15.5",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.8",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^9.39.2",
